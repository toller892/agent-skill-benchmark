+def test_modulus_basic():
+    """modulus should return remainder of a divided by b."""
+    calc = Calculator()
+    assert calc.modulus(10, 3) == 1
+    assert calc.modulus(7, 2) == 1
+
+
+def test_modulus_zero_dividend():
+    """modulus with zero dividend should return 0."""
+    calc = Calculator()
+    assert calc.modulus(0, 5) == 0
+
+
+def test_modulus_exact_division():
+    """modulus with exact division should return 0."""
+    calc = Calculator()
+    assert calc.modulus(5, 5) == 0
+
+
+def test_modulus_negative():
+    """modulus with negative numbers."""
+    calc = Calculator()
+    assert calc.modulus(-10, 3) == 2
+
+
+def test_divide_by_zero_returns_none():
+    """divide by zero should return None gracefully, not crash."""
+    calc = Calculator()
+    assert calc.divide(10, 0) is None
+
+
+def test_average_basic():
+    """average of a normal list returns the mean."""
+    calc = Calculator()
+    assert calc.average([1.0, 2.0, 3.0]) == 2.0
+
+
+def test_average_single_element():
+    """average of single-element list returns that element."""
+    calc = Calculator()
+    assert calc.average([5.0]) == 5.0
+
+
+def test_average_empty_list():
+    """average of empty list returns None."""
+    calc = Calculator()
+    assert calc.average([]) is None
+
+
+def test_average_floats():
+    """average with float values."""
+    calc = Calculator()
+    assert calc.average([1.5, 2.5]) == 2.0
